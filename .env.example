# ── Sumber data ────────────────────────────────────────────────
# Kosongkan (atau hapus) untuk mode demo in-memory — aplikasi langsung
# jalan tanpa database. Set ke "postgres" untuk memakai PostgreSQL.
# DATA_SOURCE=postgres

# ── PostgreSQL (hanya dibutuhkan saat DATA_SOURCE=postgres) ────
# Cocok dengan docker-compose.yml bawaan:
DATABASE_URL="postgresql://stem:stem@localhost:5432/stem_sultan_agung?schema=public"
